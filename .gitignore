# ============================================
# MEDAD PROJECT - MASTER .gitignore
# ============================================
# This file ensures sensitive environment 
# files are never committed to version control
# ============================================

# Environment files for both apps
.env
.env.local
.env.*.local
!.env.example

# Flutter/Dart
**/.dart_tool/
**/.flutter-plugins-dependencies
**/.pub-cache/
**/.pub/
**/build/
**/coverage/

# IDE
**/.idea/
**/.vscode/
**/*.iml

# OS
**/.DS_Store
**/Thumbs.db

# Logs
**/*.log

# Temporary files
**/tmp/
**/*.tmp
